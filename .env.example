# AnD Task B — Environment Variables
# Copy this to .env and fill in your own values.
# All variables are required unless marked optional.

# --- Application ---
APP_NAME="AnD-ai-recommendation-engine"
DEBUG=True

# --- LLM Provider (OpenRouter) ---
# Required: at least one key. Multiple keys enable automatic rotation on rate-limit.
OPENROUTER_API_KEYS=["your_openrouter_api_key_1","your_openrouter_api_key_2"]

# Primary model slug (OpenRouter format). Fallbacks are defined in config.py.
MODEL_PRIMARY="z-ai/glm-4.5-air:free"

# Max tokens per LLM response
MAX_TOKENS=1024

# --- Hugging Face ---
# Required for FAISS index build (sentence-transformers model download).
HF_TOKEN=""

# --- CORS (optional — only needed when running the FastAPI server) ---
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000,http://localhost:8001"
